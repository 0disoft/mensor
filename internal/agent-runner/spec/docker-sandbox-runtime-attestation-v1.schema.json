{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "docker-sandbox-runtime-attestation-v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "kind", "planSha256", "collector", "engine", "image", "security", "limits"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "kind": { "const": "docker-networkless-runtime" },
    "planSha256": { "$ref": "#/$defs/digest" },
    "collector": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "revision", "sha256"],
      "properties": {
        "id": { "$ref": "#/$defs/identifier" },
        "revision": { "$ref": "#/$defs/name" },
        "sha256": { "$ref": "#/$defs/digest" }
      }
    },
    "engine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "operatingSystem", "architecture"],
      "properties": {
        "name": { "const": "docker" },
        "version": { "$ref": "#/$defs/name" },
        "operatingSystem": { "const": "linux" },
        "architecture": { "$ref": "#/$defs/name" }
      }
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reference", "id"],
      "properties": {
        "reference": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._/-]*@sha256:[a-f0-9]{64}$" },
        "id": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
      }
    },
    "security": {
      "type": "object",
      "additionalProperties": false,
      "required": ["network", "rootFilesystem", "workspaceMount", "capabilities", "privilegeEscalation", "credentials", "user", "temporaryFilesystem"],
      "properties": {
        "network": { "const": "none" },
        "rootFilesystem": { "const": "read-only" },
        "workspaceMount": { "const": "read-write-only" },
        "capabilities": { "const": "none" },
        "privilegeEscalation": { "const": "disabled" },
        "credentials": { "const": "none" },
        "user": { "const": "65532:65532" },
        "temporaryFilesystem": { "const": "memory-only-noexec-nosuid" }
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["memoryMiB", "cpuCount", "pidsLimit"],
      "properties": {
        "memoryMiB": { "type": "integer", "minimum": 64, "maximum": 16384 },
        "cpuCount": { "type": "integer", "minimum": 1, "maximum": 16 },
        "pidsLimit": { "type": "integer", "minimum": 16, "maximum": 4096 }
      }
    }
  },
  "$defs": {
    "identifier": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$" },
    "name": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:+/-]{0,127}$" },
    "digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}
