{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agent-evidence-assessment-v1.schema.json",
  "title": "Mensor Agent Evidence Assessment v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "executionFingerprint",
    "claimLevel",
    "eligibleForPublicRepairRate",
    "blockers"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "executionFingerprint": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "claimLevel": { "const": "protocol-integrity-only" },
    "eligibleForPublicRepairRate": { "const": false },
    "blockers": {
      "const": [
        "credential-scope-not-attested",
        "filesystem-isolation-not-attested",
        "network-control-not-enforced",
        "process-containment-not-enforced"
      ]
    }
  }
}
