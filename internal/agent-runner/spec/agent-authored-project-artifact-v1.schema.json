{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agent-authored-project-artifact-v1.schema.json",
  "title": "Mensor Agent-Authored Project Artifact v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "kind", "files"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "kind": { "const": "agent-authored-project-artifact" },
    "files": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "content"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1,
            "maxLength": 512,
            "pattern": "^(?!/)(?!.*\\\\)(?!.*:)(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*//)[^\\u0000-\\u001f\\u007f]+$"
          },
          "content": {
            "type": "string",
            "minLength": 1,
            "maxLength": 262144,
            "pattern": "^[^\\r\\u0000-\\u0008\\u000b\\u000c\\u000e-\\u001f\\u007f]*(?:\\n)$"
          }
        }
      }
    }
  }
}
