{
  "name": "@0disoft/mensor-cli",
  "version": "0.2.0",
  "description": "CLI for checking Mensor project contracts.",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0disoft/mensor.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/0disoft/mensor#readme",
  "bugs": {
    "url": "https://github.com/0disoft/mensor/issues"
  },
  "keywords": ["mensor", "cli", "static-analysis", "contracts", "developer-tools"],
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "files": ["LICENSE", "dist/src"],
  "bin": {
    "mensor": "./dist/src/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "dependencies": {
    "@0disoft/mensor-compiler": "workspace:*"
