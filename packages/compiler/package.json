      "import": "./dist/src/index.js"
    }
  },
  "dependencies": {
    "@0disoft/mensor-contract": "workspace:*",
    "@typescript/typescript6": "6.0.2",
    "jsonc-parser": "3.3.1",
    "parse5": "8.0.1"
