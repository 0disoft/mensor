{
  "name": "@0disoft/mensor-compiler",
  "version": "0.2.0",
  "description": "Deterministic source contract checker for Mensor projects.",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0disoft/mensor.git",
    "directory": "packages/compiler"
  },
  "homepage": "https://github.com/0disoft/mensor#readme",
  "bugs": {
    "url": "https://github.com/0disoft/mensor/issues"
  },
  "keywords": ["mensor", "static-analysis", "contracts", "html", "typescript"],
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "files": ["LICENSE", "dist/src"],
