{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "diagnostic-report-v1.schema.json",
  "title": "Mensor Diagnostic Report v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "producer", "status", "diagnostics", "summary"],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": {
          "const": "mensor"
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "status": {
      "enum": ["passed", "failed"]
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/diagnostic"
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["errorCount", "warningCount"],
      "properties": {
        "errorCount": {
          "type": "integer",
          "minimum": 0
        },
        "warningCount": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  },
  "$defs": {
    "position": {
      "type": "object",
      "additionalProperties": false,
      "required": ["line", "character"],
      "properties": {
        "line": {
          "type": "integer",
          "minimum": 0
        },
        "character": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "range": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end"],
      "properties": {
        "start": {
          "$ref": "#/$defs/position"
        },
        "end": {
          "$ref": "#/$defs/position"
        }
      }
    },
    "related": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "message", "file", "range"],
      "properties": {
        "role": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "file": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"
        },
        "range": {
          "$ref": "#/$defs/range"
        }
      }
    },
    "repair": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "hint", "mustPreserve", "mustNot"],
      "properties": {
        "strategy": {
          "type": "string",
          "minLength": 1
        },
        "hint": {
          "type": "string",
          "minLength": 1
        },
        "mustPreserve": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "mustNot": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "diagnostic": {
      "oneOf": [
        {
          "$ref": "#/$defs/formFieldMissingDiagnostic"
        },
        {
          "$ref": "#/$defs/formFieldUnexpectedDiagnostic"
        },
        {
          "$ref": "#/$defs/formMethodMismatchDiagnostic"
        },
        {
          "$ref": "#/$defs/formActionMismatchDiagnostic"
        },
        {
          "$ref": "#/$defs/fileRoleMismatchDiagnostic"
        }
      ]
    },
    "diagnosticBase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "severity", "category", "message", "file", "range", "facts", "related", "repair"],
      "properties": {
        "code": {},
        "severity": {},
        "category": {},
        "message": {
          "type": "string",
          "minLength": 1
        },
        "file": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"
        },
        "range": {
          "$ref": "#/$defs/range"
        },
        "facts": {},
        "related": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/related"
          }
        },
        "repair": {
          "$ref": "#/$defs/repair"
        }
      }
    },
    "formFieldMissingDiagnostic": {
      "allOf": [
        {
          "$ref": "#/$defs/diagnosticBase"
        },
        {
          "type": "object",
          "properties": {
            "code": {
              "const": "form.field_missing"
            },
            "severity": {
              "const": "error"
            },
            "category": {
              "const": "form-contract"
            },
            "facts": {
              "$ref": "#/$defs/formFieldMissingFacts"
            }
          }
        }
      ]
    },
    "formFieldMissingFacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actionId", "fieldName", "formId", "schemaPath", "template"],
      "properties": {
        "actionId": {
          "type": "string",
          "minLength": 1
        },
        "fieldName": {
          "type": "string",
          "minLength": 1
        },
        "formId": {
          "type": "string",
          "minLength": 1
        },
        "schemaPath": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "template": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"
        }
      }
    },
    "formFieldUnexpectedDiagnostic": {
      "allOf": [
        {
          "$ref": "#/$defs/diagnosticBase"
        },
        {
          "type": "object",
          "properties": {
            "code": {
              "const": "form.field_unexpected"
            },
            "severity": {
              "const": "error"
            },
            "category": {
              "const": "form-contract"
            },
            "facts": {
              "$ref": "#/$defs/formFieldUnexpectedFacts"
            }
          }
        }
      ]
    },
    "formFieldUnexpectedFacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actionId", "fieldName", "formId", "template", "unknownFieldsPolicy"],
      "properties": {
        "actionId": {
          "type": "string",
          "minLength": 1
        },
        "fieldName": {
          "type": "string",
          "minLength": 1
        },
        "formId": {
          "type": "string",
          "minLength": 1
        },
        "template": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"
        },
        "unknownFieldsPolicy": {
          "const": "reject"
        }
      }
    },
    "formMethodMismatchDiagnostic": {
      "allOf": [
        {
          "$ref": "#/$defs/diagnosticBase"
        },
        {
          "type": "object",
          "properties": {
            "code": {
              "const": "form.method_mismatch"
            },
            "severity": {
              "const": "error"
            },
            "category": {
              "const": "form-contract"
            },
            "facts": {
              "$ref": "#/$defs/formMethodMismatchFacts"
            }
          }
        }
      ]
    },
    "formMethodMismatchFacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actionId", "actualMethod", "expectedMethod", "formId", "template"],
      "properties": {
        "actionId": {
          "type": "string",
          "minLength": 1
        },
        "actualMethod": {
          "type": "string"
        },
        "expectedMethod": {
          "const": "POST"
        },
        "formId": {
          "type": "string",
          "minLength": 1
        },
        "template": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"
        }
      }
    },
    "formActionMismatchDiagnostic": {
      "allOf": [
        {
          "$ref": "#/$defs/diagnosticBase"
        },
        {
          "type": "object",
          "properties": {
            "code": {
              "const": "form.action_mismatch"
            },
            "severity": {
              "const": "error"
            },
            "category": {
              "const": "form-contract"
            },
            "facts": {
              "$ref": "#/$defs/formActionMismatchFacts"
            }
          }
        }
      ]
    },
    "formActionMismatchFacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actionId", "actualAction", "expectedAction", "formId", "template"],
      "properties": {
        "actionId": {
          "type": "string",
          "minLength": 1
        },
        "actualAction": {
          "type": "string"
        },
        "expectedAction": {
          "type": "string",
          "minLength": 1
        },
        "formId": {
          "type": "string",
          "minLength": 1
        },
        "template": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"
        }
      }
    },
    "fileRoleMismatchDiagnostic": {
      "allOf": [
        {
          "$ref": "#/$defs/diagnosticBase"
        },
        {
          "type": "object",
          "properties": {
            "code": {
              "const": "file.role_mismatch"
            },
            "severity": {
              "const": "error"
            },
            "category": {
              "const": "project-structure"
            },
            "facts": {
              "$ref": "#/$defs/fileRoleMismatchFacts"
            }
          }
        }
      ]
    },
    "fileRoleMismatchFacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actionId", "actualRole", "expectedRole", "expectedWithinFeature", "featureId", "handlerFile"],
      "properties": {
        "actionId": {
          "type": "string",
          "minLength": 1
        },
        "actualRole": {
          "type": "string",
          "minLength": 1
        },
        "expectedRole": {
          "type": "string",
          "minLength": 1
        },
        "expectedWithinFeature": {
          "type": "string",
          "minLength": 1
        },
        "featureId": {
          "type": "string",
          "minLength": 1
        },
        "handlerFile": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"
        }
      }
    }
  }
}
