{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "project-contract-v1.schema.json",
  "title": "Mensor Project Contract v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "sourceRoot", "featureContracts"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "const": 1
    },
    "sourceRoot": {
      "$ref": "#/$defs/relativePath"
    },
    "featureContracts": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/relativePath"
      }
    }
  },
  "$defs": {
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"
    }
  }
}
