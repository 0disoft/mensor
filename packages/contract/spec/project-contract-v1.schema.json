{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "project-contract-v1.schema.json",
  "title": "Mensor Project Contract v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "sourceRoot", "featureContracts", "fileRoles"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "const": 1
    },
    "sourceRoot": {
      "$ref": "#/$defs/relativePath"
    },
    "featureContracts": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/relativePath"
      }
    },
    "fileRoles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/fileRole"
      }
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"
    },
    "featureDirectory": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\)(?!.*//$)(?!.*(?:^|/)\\.(?:/|$)).*[^/]$"
    },
    "fileRole": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "withinFeature"],
      "properties": {
        "role": {
          "$ref": "#/$defs/identifier"
        },
        "withinFeature": {
          "$ref": "#/$defs/featureDirectory"
        }
      }
    }
  }
}
