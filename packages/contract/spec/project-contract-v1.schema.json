{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "project-contract-v1.schema.json",
  "title": "Mensor Project Contract v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "sourceRoot", "featureContracts", "fileRoles"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "const": 1
    },
    "sourceRoot": {
      "$ref": "#/$defs/relativePath"
    },
    "featureContracts": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/relativePath"
      }
    },
    "fileRoles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/fileRole"
      }
    },
    "boundaries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/boundary"
      }
    },
    "ownershipRules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ownershipRule"
      }
    },
    "routeIndex": {
      "$ref": "#/$defs/relativePath"
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"
    },
    "featureDirectory": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\)(?!.*//$)(?!.*(?:^|/)\\.(?:/|$)).*[^/]$"
    },
    "fileRole": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "withinFeature"],
      "properties": {
        "role": {
          "$ref": "#/$defs/identifier"
        },
        "withinFeature": {
          "$ref": "#/$defs/featureDirectory"
        }
      }
    },
    "boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "mode", "from", "deny"],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "mode": {
          "enum": ["direct", "transitive"]
        },
        "from": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "deny": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        }
      }
    },
    "ownershipRule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "suffixes", "withinFeature"],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "kind": {
          "enum": ["i18n", "test"]
        },
        "suffixes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^\\.[A-Za-z0-9._-]+$"
          }
        },
        "withinFeature": {
          "$ref": "#/$defs/featureDirectory"
        }
      }
    }
  }
}
