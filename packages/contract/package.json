{
  "name": "@0disoft/mensor-contract",
  "version": "0.2.0",
  "description": "Serializable contracts, schemas, and deterministic diagnostics for Mensor.",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0disoft/mensor.git",
    "directory": "packages/contract"
  },
  "homepage": "https://github.com/0disoft/mensor#readme",
  "bugs": {
    "url": "https://github.com/0disoft/mensor/issues"
  },
  "keywords": ["mensor", "contracts", "diagnostics", "json-schema", "developer-tools"],
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "files": [
    "LICENSE",
    "dist/src",
    "dist/spec"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./schemas/project-contract-v1.schema.json": "./dist/spec/project-contract-v1.schema.json",
    "./schemas/feature-contract-v1.schema.json": "./dist/spec/feature-contract-v1.schema.json",
    "./schemas/diagnostic-report-v1.schema.json": "./dist/spec/diagnostic-report-v1.schema.json",
    "./schemas/check-output-v2.schema.json": "./dist/spec/check-output-v2.schema.json",
    "./schemas/route-index-v1.schema.json": "./dist/spec/route-index-v1.schema.json"
  },
  "dependencies": {
    "ajv": "8.20.0",
    "jsonc-parser": "3.3.1"
  }
}
