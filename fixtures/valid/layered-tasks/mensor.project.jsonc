{
  "$schema": "../../../packages/contract/spec/project-contract-v1.schema.json",
  "version": 1,
  "sourceRoot": "src",
  "featureContracts": ["src/features/tasks/feature.mensor.jsonc"],
  "fileRoles": [
    { "role": "server", "withinFeature": "server" },
    { "role": "route", "withinFeature": "routes" },
    { "role": "view", "withinFeature": "views" },
    { "role": "browser", "withinFeature": "browser" },
    { "role": "shared", "withinFeature": "shared" },
    { "role": "database", "withinFeature": "database" }
  ],
  "boundaries": [
    {
      "id": "browser-no-server",
      "mode": "transitive",
      "from": ["browser"],
      "deny": ["server", "database"]
    },
    {
      "id": "route-no-database",
      "mode": "direct",
      "from": ["route"],
      "deny": ["database"]
    }
  ],
  "ownershipRules": [
    {
      "id": "feature-tests",
      "kind": "test",
      "suffixes": [".test.ts"],
      "withinFeature": "tests"
    },
    {
      "id": "feature-messages",
      "kind": "i18n",
      "suffixes": [".messages.json"],
      "withinFeature": "i18n"
    }
  ]
}
